{
  "name": "key-quest",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:headed": "playwright test --headed --reporter=list",
    "test:e2e:cleanup": "node tests/e2e/global.teardown.js",
    "test:all": "echo \"Running unit tests...\" && npm run test:unit && echo \"Running end-to-end tests...\" && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^5.0.0",
    "dotenv": "^17.4.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.4"
  }
}
